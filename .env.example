# ============================================
# AgentAudit — Sepolia 测试网环境配置
# ============================================
# 复制此文件为 .env 并填入实际值

# ── Sepolia 测试网 RPC URL ──────────────────
# 推荐: Alchemy / Infura / QuickNode
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ── 部署者私钥 (请勿提交到代码仓库) ────────
PRIVATE_KEY=0x_your_private_key_here

# ── 是否启用 Gas 报告 ──────────────────────
REPORT_GAS=false

# ── 合约地址 (部署后自动生成，需填入) ──────
TASK_MANAGER_ADDRESS=
BOUNTY_ESCROW_ADDRESS=
AGENT_REGISTRY_ADDRESS=
DEADLINE_CONTROLLER_ADDRESS=
SETTLEMENT_ADDRESS=
REPUTATION_SYSTEM_ADDRESS=
USDC_TOKEN_ADDRESS=

# ── 链 ID ──────────────────────────────────
CHAIN_ID=11155111

# ── Supabase 存储 (可选) ────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── 模块4 数据库 URL (SQLite 默认) ─────────
DATABASE_URL=sqlite+aiosqlite:///./vuln_clustering.db

# ── 模块5 数据库 URL (SQLite 默认) ─────────
DATABASE_URL_M5=file:./dev.db

# ── LLM API Key (模块2/模块4) ───────────────
OPENAI_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
